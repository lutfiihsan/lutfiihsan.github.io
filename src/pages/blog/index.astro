---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Blog | Lutfi Ihsan — Full Stack Developer"
  description="Artikel, tutorial, dan insight seputar Full Stack Development, SysAdmin, Laravel, dan teknologi modern dari Lutfi Ihsan."
  canonical="/blog/"
  extraCss={['/assets/css/blog.css']}
  extraScripts={['/assets/js/blog.js']}
>
  <main>
    <section class="blog-hero">
      <div class="blog-hero-content">
        <div class="hero-badge"><i class="fas fa-pencil-alt"></i> Blog & Tulisan</div>
        <h1>Tulisan <span>Teknis</span> & Insight</h1>
        <p>Catatan, tutorial, dan pemikiran seputar Full Stack Development, SysAdmin, dan teknologi modern.</p>
      </div>
    </section>

    <section class="blog-section">
      <div class="blog-container">
        <div id="blog-posts-grid" class="blog-grid">
          <div class="blog-loading"><i class="fas fa-spinner fa-spin"></i> Memuat artikel...</div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
