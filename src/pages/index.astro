---
import BaseLayout from '../layouts/BaseLayout.astro';
import homeContent from '../content/home.html?raw';
import { PERSON_JSON_LD, SITE, WEBSITE_JSON_LD } from '../lib/site';

const html = homeContent
  .replaceAll('./assets/', '/assets/')
  .replaceAll('â€"', '—');
---

<BaseLayout
  title={SITE.title}
  description={SITE.defaultDescription}
  canonical="/"
  lang="en"
  jsonLd={[PERSON_JSON_LD, WEBSITE_JSON_LD]}
>
  <main id="main-content" set:html={html} />
</BaseLayout>
