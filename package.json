{
  "name": "lutfiihsan.github.io",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:site": "astro dev",
    "dev:admin": "vite --config vite.admin.config.js",
    "dev:api": "wrangler dev",
    "build": "astro build && vite build --config vite.admin.config.js",
    "preview": "astro preview",
    "deploy:api": "wrangler deploy",
    "deploy:pages": "npm run build",
    "db:migrate": "wrangler d1 execute myporto-db --local --file=./worker/schema.sql",
    "db:migrate:remote": "wrangler d1 execute myporto-db --remote --file=./worker/schema.sql",
    "db:migrate:portfolio": "wrangler d1 execute myporto-db --remote --file=./worker/migrations/002_portfolio.sql",
    "db:create": "wrangler d1 create myporto-db",
    "setup:cloudflare": "node scripts/setup-cloudflare.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@vitejs/plugin-react": "^6.0.2",
    "astro": "^6.4.8",
    "hono": "^4.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.8",
    "vite-plugin-html-inject": "^1.1.2",
    "wrangler": "^3.109.2"
  }
}
